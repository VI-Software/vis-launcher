<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8"/>
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline'"/>
    <title>VI Software Mod Store</title>
    <link type="text/css" rel="stylesheet" href="./assets/css/modstore.css">
</head>
<body>
    <div id="frame_bar" class="frame_bar_<%= process.platform %>">
        <% if (process.platform === 'darwin') { %>
        <!-- macOS style traffic lights -->
        <div id="frame_buttons_darwin" class="frame_buttons_darwin">
            <button id="frame_button_close" class="frame_button_darwin frame_button_close_darwin" title="Close"></button>
            <button id="frame_button_minimize" class="frame_button_darwin frame_button_minimize_darwin" title="Minimize"></button>
            <button id="frame_button_maximize" class="frame_button_darwin frame_button_maximize_darwin" title="Maximize"></button>
        </div>
        <div id="frame_title_darwin" class="frame_title_darwin">VI Software Mod Store</div>
        <% } else { %>
        <!-- Windows/Linux style -->
        <div id="frame_title">VI Software Mod Store</div>
        <div id="frame_buttons">
            <button id="frame_button_minimize" class="frame_button" title="Minimize">
                <svg name="TitleBarMinimize" width="10" height="10" viewBox="0 0 12 12"><rect stroke="#ffffff" fill="#ffffff" width="10" height="1" x="1" y="6"></rect></svg>
            </button>
            <button id="frame_button_maximize" class="frame_button" title="Maximize">
                <svg name="TitleBarMaximize" width="10" height="10" viewBox="0 0 12 12"><rect width="9" height="9" x="1.5" y="1.5" fill="none" stroke="#ffffff" stroke-width="1.4px"></rect></svg>
            </button>
            <button id="frame_button_close" class="frame_button" title="Close">
                <svg name="TitleBarClose" width="10" height="10" viewBox="0 0 12 12"><polygon stroke="#ffffff" fill="#ffffff" fill-rule="evenodd" points="11 1.576 6.583 6 11 10.424 10.424 11 6 6.583 1.576 11 1 10.424 5.417 6 1 1.576 1.576 1 6 5.417 10.424 1"></polygon></svg>
            </button>
        </div>
        <% } %>
    </div>

    <div id="mod_store_wrapper">
        <%- include('modstore-content.ejs') %>
    </div>

    <script src="./assets/js/scripts/modstore.js"></script>
</body>
</html>
